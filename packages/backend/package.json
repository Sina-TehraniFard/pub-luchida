{
  "name": "@luchida/backend",
  "version": "0.9.2",
  "private": true,
  "type": "module",
  "exports": {
    "./domain/*.js": {
      "types": "./src/domain/*.ts",
      "default": "./dist/domain/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "test:integration": "node --env-file=.env node_modules/.bin/vitest run --config vitest.config.integration.ts",
    "db:generate": "node --env-file=.env ../../node_modules/.bin/drizzle-kit generate",
    "db:migrate": "node --env-file=.env ../../node_modules/.bin/drizzle-kit migrate",
    "start": "node --env-file=.env --import tsx src/main.ts"
  },
  "dependencies": {
    "big.js": "^7.0.1",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "socket.io": "^4.8.3",
    "trading-signals": "^7.4.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/big.js": "^6.1.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.9",
    "vitest": "^4.1.9"
  }
}
