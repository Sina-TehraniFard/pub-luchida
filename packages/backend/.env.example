# GMO FX API 認証情報
# https://coin.z.com/jp/corp/product/info/fx/api/ で取得
GMO_API_KEY=your_api_key_here
GMO_API_SECRET=your_api_secret_here

# PostgreSQL 接続（docker-compose.yml のデフォルト設定に合わせてある）
DATABASE_URL=postgresql://luchida:luchida@localhost:5432/luchida

# 運用資金（円）。1万円につき1,000通貨で自動計算
CAPITAL=100000

# API 認証トークン（未設定の場合は認証なし）
API_TOKEN=your_api_token_here
