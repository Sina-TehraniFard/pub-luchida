                </mxCell>
                <mxCell id="note_design" value="設計方針&#10;&#10;- positions: ドメインの核心。ライフサイクル管理のみ&#10;- position_entry_snapshots: 分析データ。独立して育てる&#10;- 1:1関係。エントリー時に同時INSERT&#10;- snapshotsは全列NULL許容（後方互換）&#10;- 1日最大100〜1000件。2テーブルINSERTのコストは無視できる&#10;- 削除ではなくステータス変更&#10;- exit_type/exit_reason で決済理由を直接記録&#10;- mfe_pips/mae_pips でSL最適化分析が可能" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=11;fontColor=#997a2d;align=left;" parent="1" vertex="1">
                    <mxGeometry x="375" y="629" width="340" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="note_query" value="クエリ例&#10;&#10;保有中: WHERE status = 'OPEN'&#10;利確: WHERE profit_loss &gt; 0&#10;損切: WHERE profit_loss &lt; 0&#10;&#10;-- スプレッドコスト分析&#10;JOIN position_entry_snapshots s ON id = s.position_id&#10;WHERE s.spread_pips &gt; 2.0&#10;&#10;-- 高確信 × トレンド相場 × 順張り&#10;WHERE s.conviction_score &gt;= 0.7&#10;  AND s.adx &gt;= 25&#10;  AND s.trend_alignment = 1" style="shape=note;whiteSpace=wrap;size=14;fillColor=#e8f5e9;strokeColor=#82b366;fontSize=11;fontColor=#3a6b2a;align=left;" parent="1" vertex="1">
                    <mxGeometry x="900" y="625" width="360" height="240" as="geometry"/>
                </mxCell>
