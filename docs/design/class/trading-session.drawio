                <mxCell id="note_ts" value="段取り役（Application Service）&#10;start()でCandleHistoryPortから過去足を取得しwarmUp→市場監視開始&#10;市場データが来たらRuleを呼ぶ&#10;EntryCommand → 自動発注 + UIにシグナル通知&#10;ExitCommand → 即座にExitExecutionで自動決済&#10;entryInProgress/exitInProgressで並行評価を防止" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=11;fontColor=#997a2d;align=left;" parent="1" vertex="1">
                    <mxGeometry x="436" y="-1" width="390" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="note_ts_arr" style="strokeColor=#d6b656;dashed=1;endArrow=none;" parent="1" source="note_ts" target="ts" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="note_mds" value="薄いブリッジ（Infrastructure層）&#10;tick受信 → TimeFrameBookに渡す → MarketSnapshot受取 → listener通知&#10;WebSocket購読・再接続はMarketDataPort実装（Adapter層）の責務&#10;自身はtickの加工もSnapshot組立もしない" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=11;fontColor=#997a2d;align=left;" parent="1" vertex="1">
                    <mxGeometry x="794" y="731" width="393" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="note_mds_arr" style="strokeColor=#d6b656;dashed=1;endArrow=none;" parent="1" source="note_mds" target="mds" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="note_er" value="各tick: shouldEntry(market) を呼ぶ&#10;EntryCommand → 自動発注 + UIにシグナル通知&#10;DoNothing → 何もしない" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=11;fontColor=#997a2d;align=left;" parent="1" vertex="1">
                    <mxGeometry x="60" y="10" width="250" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="note_er_arr" style="strokeColor=#d6b656;dashed=1;endArrow=none;" parent="1" source="note_er" target="entry_rule" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="note_xr" value="決済の権威（3大権威の1つ）&#10;ExitCommand → 即座に自動決済（ユーザー承認不要）&#10;ポジションごとに独立判定" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=11;fontColor=#997a2d;align=left;" parent="1" vertex="1">
                    <mxGeometry x="63" y="225" width="250" height="70" as="geometry"/>
