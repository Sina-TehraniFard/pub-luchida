                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="note_cal" value="TradingGuard（次フェーズ）は&#10;TradingSessionで制御する&#10;取引禁止中はCommandを握りつぶす&#10;経済指標・APIメンテ・異常検知で発動" style="shape=note;whiteSpace=wrap;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="792.5" y="659" width="396" height="70" as="geometry"/>
