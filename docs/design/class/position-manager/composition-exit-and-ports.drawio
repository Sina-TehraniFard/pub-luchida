                <mxCell id="alertPortR" value="&lt;&lt;interface&gt;&gt;&#10;AlertPort" style="swimlane;fontStyle=1;align=center;startSize=45;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontColor=#000000;" parent="1" vertex="1">
