                <mxCell id="eImpl_Alert" value="implements" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=0;dashed=1;strokeColor=#444444;labelBackgroundColor=#ffffff;fontSize=10;fontColor=#000000;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="alertAdapter" target="alertPortR" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- ====== 付箋（右端） ====== -->
                <mxCell id="groupNotes" value="設計のポイント" style="shape=mxgraph.basic.rect;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=4;rounded=1;arcSize=4;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1440" y="100" width="530" height="1200" as="geometry"/>
                </mxCell>

                <mxCell id="note1" value="TradingSession の戦略別 dispatch（policies.md 2.5 / N-C1）&#10;&#10;・exitRulesByStrategy: Map&lt;StrategyNameValue, ExitRule&gt;&#10;・openPositions.sortedByOpenedAtAsc() で評価順を決定論化（H12）&#10;・1 戦略の throw で他戦略評価を止めない（try/catch + 'error' 通知）&#10;・登録漏れ戦略は AlertPort.notify('warn', 'ExitRule not registered')&#10;&#10;決済は完全自動。ユーザー承認不要。&#10;条件成立 → 即執行（brief.md 3 大権威）。" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="140" width="490" height="220" as="geometry"/>
                </mxCell>

                <mxCell id="note2" value="GmoBalanceAdapter の内部実装&#10;&#10;・5 秒 TTL キャッシュ&#10;・API 失敗 → null を返す（隠蔽しない）&#10;・application 層で CAPITAL にフォールバック&#10;&#10;キャッシュは実装詳細なのでクラス名には出さない。&#10;BalanceCache → GmoBalanceAdapter に改名。" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="380" width="490" height="220" as="geometry"/>
                </mxCell>

                <mxCell id="note3" value="Clean Architecture のオニオン構造&#10;&#10;依存方向:&#10;domain → application → port ← adapter ← infrastructure&#10;（矢印は内側へ。実装は外側から）&#10;&#10;・domain は何にも依存しない（最も純粋）&#10;・port は &lt;&lt;interface&gt;&gt; だけ。実装は持たない&#10;・adapter が port を implements&#10;・GMO API の都合変更で domain を書き換えない（案 C 却下の核心）" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="620" width="490" height="230" as="geometry"/>
                </mxCell>

                <mxCell id="note4" value="PositionRepository の OPEN 部分ユニーク&#10;&#10;・(pair, strategy_name) で OPEN は 1 つだけ&#10;・WHERE status = &apos;OPEN&apos; の部分インデックス&#10;・CLOSED は何本あっても OK&#10;&#10;戦略ごとに独立したポジション管理。&#10;制約緩和で将来「同戦略複数ポジション」に広げられる。" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="870" width="490" height="230" as="geometry"/>
                </mxCell>

                <!-- ====== エッジ ====== -->
                <!-- 左レーン: TradingSession -> ExitRule(ref), Position(ref) -->
                <mxCell id="eTS_ExitRule" value="evaluates" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=open;dashed=1;strokeColor=#444444;labelBackgroundColor=#ffffff;fontSize=10;fontColor=#000000;exitX=0.8;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="tradingSession" target="exitRuleRef" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="eTS_Position" value="reads" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=open;dashed=1;strokeColor=#444444;labelBackgroundColor=#ffffff;fontSize=10;fontColor=#000000;exitX=0.2;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="tradingSession" target="positionRef" edge="1">
