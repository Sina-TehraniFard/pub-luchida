                <mxCell id="pgPosRepo" value="PostgresPositionRepository" style="swimlane;fontStyle=1;align=center;startSize=35;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontColor=#000000;" parent="1" vertex="1">
