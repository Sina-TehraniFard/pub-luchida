                    <mxGeometry x="1130" y="1100" width="270" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="alertAdapterContent" value="--&#10;+ notify(level, message, ctx)&#10;{Slack / Discord / Webhook 等}&#10;{実装は別 issue で確定（M9）}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#d5e8d4;strokeColor=none;fontSize=10;fontColor=#000000;" parent="alertAdapter" vertex="1">
                    <mxGeometry y="35" width="270" height="95" as="geometry"/>
                </mxCell>

                <mxCell id="eImpl_Clock" value="implements" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=0;dashed=1;strokeColor=#444444;labelBackgroundColor=#ffffff;fontSize=10;fontColor=#000000;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="systemClockAdapter" target="clockPortR" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
