                    <mxGeometry x="30" y="100" width="720" height="1200" as="geometry"/>
                </mxCell>
                <mxCell id="lanePorts" value="右レーン: Port → Adapter 実装" style="shape=mxgraph.basic.rect;fillColor=#f5e6ff;strokeColor=#c299ff;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=4;rounded=0;fontColor=#555555;" parent="1" vertex="1">
                    <mxGeometry x="780" y="100" width="640" height="1200" as="geometry"/>
                </mxCell>

                <!-- ====== 左レーン: 決済フロー ====== -->
                <!-- TradingSession (最上段) -->
                <mxCell id="tradingSession" value="TradingSession&#10;（市場監視ループ、複数 Rule を for 評価）" style="swimlane;fontStyle=1;align=center;startSize=45;strokeWidth=2;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="70" y="150" width="640" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="tradingSessionContent" value="- exitRulesByStrategy: Map&lt;StrategyNameValue, ExitRule&gt;（戦略別 dispatch / N-C1）&#10;- exitExecution: ExitExecution&#10;- positionRepository: PositionRepository&#10;- alertPort: AlertPort&#10;--&#10;+ evaluateEntry(snapshot): void → PositionManager.handleSignals&#10;+ evaluateExit(snapshot): void&#10;  ※ 再入防止: exitInProgress フラグで同時実行を直列化（ティック重複時の OPEN 競合を防ぐ）&#10;  for ordered := openPositions.sortedByOpenedAtAsc():&#10;    rule = exitRulesByStrategy.get(p.strategyName.value)&#10;    if !rule → AlertPort.notify('warn', 'ExitRule not registered'); continue&#10;    try { result = rule.shouldExit(p, snapshot) }&#10;    catch → AlertPort.notify('error', ...) (H12 / 1 戦略の throw で他戦略を止めない)&#10;    if result instanceof ExitCommand → exitExecution.closePosition" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#dae8fc;strokeColor=none;fontSize=11;fontColor=#000000;" parent="tradingSession" vertex="1">
                    <mxGeometry y="45" width="640" height="115" as="geometry"/>
                </mxCell>

                <!-- ExitRule(ref) 右側に小さく参照 -->
                <mxCell id="exitRuleRef" value="ExitRule&#10;（別図: rule-layer.drawio）" style="swimlane;fontStyle=1;align=center;startSize=40;fillColor=#fff2e6;strokeColor=#ffb380;fontSize=11;fontColor=#555555;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="490" y="370" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="exitRuleRefContent" value="&lt;&lt;interface&gt;&gt;&#10;+ shouldExit(position, snapshot): ExitCommand | DoNothing&#10;{null は返さない（DoNothing パターン）}&#10;{戦略ごとに 1 実装、Map に登録}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#fff2e6;strokeColor=none;fontSize=10;fontColor=#555555;" parent="exitRuleRef" vertex="1">
                    <mxGeometry y="40" width="220" height="60" as="geometry"/>
                </mxCell>

                <!-- Position(ref) 左側 -->
                <mxCell id="positionRef" value="Position&#10;（別図: value-objects-trading）" style="swimlane;fontStyle=1;align=center;startSize=40;fillColor=#fff2e6;strokeColor=#ffb380;fontSize=11;fontColor=#555555;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="370" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="positionRefContent" value="id, pair, buySell, lot,&#10;strategyName, entrySnapshot&#10;{domain 集約}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#fff2e6;strokeColor=none;fontSize=10;fontColor=#555555;" parent="positionRef" vertex="1">
                    <mxGeometry y="40" width="220" height="60" as="geometry"/>
                </mxCell>

                <!-- ExitExecution -->
                <mxCell id="exitExec" value="ExitExecution&#10;（決済執行）" style="swimlane;fontStyle=1;align=center;startSize=40;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="180" y="560" width="420" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="exitExecContent" value="- broker: Broker&#10;- positionRepository: PositionRepository&#10;- alertPort: AlertPort&#10;--&#10;+ closePosition(cmd: ExitCommand): void&#10;  broker.placeExit(cmd, clientOrderId)（clientOrderId 必須 / 冪等キー方式で重複決済防止）&#10;  ※ 補助: 再試行前に Broker.findRecentExitOrder で約定状態を事前チェック&#10;  → 約定済みなら placeExit を skip して positionRepository.update のみ実行&#10;  リトライ最大 3 回 → 全失敗時は AlertPort.notify('critical', '決済失敗・要手動対応')" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#dae8fc;strokeColor=none;fontSize=11;fontColor=#000000;" parent="exitExec" vertex="1">
                    <mxGeometry y="40" width="420" height="90" as="geometry"/>
                </mxCell>

