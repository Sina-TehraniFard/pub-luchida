                </mxCell>
                <mxCell id="title" value="PositionManager 構成図 — 決済フロー + Port / Adapter" style="text;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
