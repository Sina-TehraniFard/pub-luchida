                <mxCell id="strategyNameRefContent" value="value: StrategyNameValue&#10;{'SMA_CROSS' | 'RSI_REVERSAL'&#10; | 'SMA_DISTANCE' | 'WICK_REVERSAL'}&#10;{Map キーは .value で string 化（N-C1）}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#f5f5f5;strokeColor=none;fontSize=10;fontColor=#555555;" parent="strategyNameRef" vertex="1">
