                <mxCell id="groupNotes" value="設計のポイント" style="shape=mxgraph.basic.rect;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=4;rounded=1;arcSize=4;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="30" y="660" width="1380" height="500" as="geometry"/>
                </mxCell>

                <mxCell id="note1" value="TotalUnits は『合計』専用の VO&#10;&#10;・Lot は単一ポジション制約（100〜500,000、100 倍数）&#10;・TotalUnits は合計値専用（上限・倍数制約なし、非負のみ）&#10;・isExceedingSingleLotLimit() の内部で 500,000 と比較&#10;  → 外部に SINGLE_LOT_MAX 等の生定数を漏らさない&#10;&#10;失敗パターン: 4戦略 × 200,000 Lot = 800,000 を Lot.of に渡すと throw。&#10;合計値は必ず TotalUnits に入れる。" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="50" y="700" width="650" height="200" as="geometry"/>
                </mxCell>

                <mxCell id="note2" value="StrategyLots は『LotAllocation.apply の戻り型』&#10;&#10;・以前は Map&lt;StrategyName, Lot&gt; を直接返していた&#10;・→ 呼び出し側が for...of で順序依存ロジックを書ける&#10;・→ 設計憲法 6.10「キー順序非依存」が崩れる&#10;&#10;StrategyLots VO 経由にすることで:&#10;・lotOf(strategy) で個別問い合わせ&#10;・totalLot() で合計を TotalUnits 型として取得&#10;・生 Map は外に一切露出しない" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="730" y="700" width="650" height="200" as="geometry"/>
                </mxCell>

                <mxCell id="note3" value="SizingResult はレート二重取得を防ぐ（NH-2）&#10;&#10;・PositionSizingService.executeWithFresh(pair) で 1 回 RatePort.currentFresh を呼ぶ&#10;・取得した rate を SizingResult に閉じ込める&#10;・PositionManager は SizingResult.rate() を使い回し、再度 currentFresh を呼ばない&#10;&#10;requiredMargin = rate × lot × marginRate を生成時に計算しておくことで、&#10;EntryQueue.reservedMargin() は『保持済みの値を合算するだけの純関数』になる。" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="50" y="920" width="650" height="220" as="geometry"/>
                </mxCell>

                <mxCell id="note4" value="設計憲法（value-objects.md 6 章）と本図の対応&#10;&#10;・6.1 Big 徹底 → SizingResult.of の requiredMargin 計算は Big で完結&#10;・6.7 null 排除 → DetectedSignals.contains は bool、isEmpty で表現&#10;・6.10 Map 非露出 → StrategyLots / LotAllocation の API 設計の核心&#10;・6.5/6.6 Map キーは StrategyNameValue（N-C1）&#10;&#10;集約 VO は『結果の入れ物』。生成元のロジックは:&#10;・LotAllocation: AllocationPolicy.decide&#10;・StrategyLots: LotAllocation.apply(baseLot)&#10;・SizingResult: PositionSizingService.executeWithFresh(pair)&#10;・DetectedSignals: PositionManager の Detect 段" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="730" y="920" width="650" height="220" as="geometry"/>
                </mxCell>

                <mxCell id="eAlloc_StratLots" value="apply(baseLot)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=open;dashed=1;strokeColor=#444444;labelBackgroundColor=#ffffff;fontSize=10;fontColor=#000000;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.3;entryY=1;entryDx=0;entryDy=0;" parent="1" source="lotAllocationRef" target="strategyLots" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
