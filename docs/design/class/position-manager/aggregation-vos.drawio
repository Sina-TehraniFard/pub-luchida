                <mxCell id="availableBalanceRef" value="AvailableBalance（将来 / P4）" style="swimlane;fontStyle=1;align=center;startSize=30;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontColor=#555555;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1020" y="525" width="320" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="availableBalanceRefContent" value="{将来切り出し: 含み損益込み利用可能残高}&#10;{現状は Balance に統合（policies.md 1.6.1）}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#f5f5f5;strokeColor=none;fontSize=10;fontColor=#555555;" parent="availableBalanceRef" vertex="1">
                    <mxGeometry y="30" width="320" height="50" as="geometry"/>
