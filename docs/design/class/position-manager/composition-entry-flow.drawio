                <mxCell id="layerApp" value="application 層" style="shape=mxgraph.basic.rect;fillColor=#e6f2ff;strokeColor=#99c2ff;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=4;rounded=0;fontColor=#555555;" parent="1" vertex="1">
