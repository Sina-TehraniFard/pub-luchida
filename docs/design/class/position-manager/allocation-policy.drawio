                <mxCell id="lotAlloc" value="LotAllocation 配分結果（値オブジェクト）" style="swimlane;fontStyle=1;align=center;startSize=45;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="57" y="367" width="560" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="lotAllocContent" value="- ratios: Map&lt;StrategyNameValue, Ratio&gt;&#10;{不変条件: 合計 = 1.0、|sum-1| &lt;= Ratio.EPSILON}&#10;{全戦略抑制時のみ合計 0.0 を許容}&#10;{Map は外に露出させない（憲法 6.10）}&#10;--&#10;+ of(entries): LotAllocation&#10;+ suppressed(strategies): LotAllocation（全戦略ゼロ）&#10;+ ratioOf(strategy): Ratio&#10;+ isSuppressed(strategy): bool&#10;+ isFullySuppressed(): bool&#10;+ apply(baseLot: Lot): StrategyLots&#10;+ strategies(): StrategyName[]" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#fff2cc;strokeColor=none;fontSize=11;fontColor=#000000;" parent="lotAlloc" vertex="1">
                    <mxGeometry y="45" width="560" height="195" as="geometry"/>
                </mxCell>
                <mxCell id="policyIf" value="&lt;&lt;interface&gt;&gt;&#10;AllocationPolicy" style="swimlane;fontStyle=1;align=center;startSize=45;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="200" y="660" width="600" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="policyIfContent" value="+ decide(context: AllocationContext): LotAllocation&#10;--&#10;{純粋ドメインサービス。I/O を持たない}&#10;{検知シグナル・保有・利用可能残高 → 配分}&#10;{LotPolicy.decide(input) と命名対称}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#e1d5e7;strokeColor=none;fontSize=12;fontColor=#000000;" parent="policyIf" vertex="1">
                    <mxGeometry y="45" width="600" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="equalWeight" value="EqualWeightAllocationPolicy&#10;（初期実装 / 今回スコープ）" style="swimlane;fontStyle=1;align=center;startSize=45;strokeWidth=2;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="180" y="880" width="640" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="equalWeightContent" value="+ decide(context): LotAllocation&#10;--&#10;ロジック（残余寄せ / N-H5）:&#10; 1. n = detectedSignals.size()&#10; 2. r = (1 / n).round(10, RoundDown)&#10; 3. 先頭 n-1 戦略に r を割り当て&#10; 4. 末尾戦略に 1 - (n-1) × r（残余）を割り当て&#10; 5. 合計 = 1.0 を厳密に保ったまま LotAllocation.of に渡す&#10;--&#10;{合計ロット上限超過時のスケールダウンは PositionManager 側の責務}&#10;{Allocation 段では行わない（policies.md 1.11）}&#10;--&#10;{無知に対する最適解（DeMiguel 2009）}&#10;{Kelly 誤差ペナルティも小さい}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#d5e8d4;strokeColor=none;fontSize=11;fontColor=#000000;" parent="equalWeight" vertex="1">
                    <mxGeometry y="45" width="640" height="235" as="geometry"/>
                </mxCell>
                <mxCell id="arrCtxDetected" value="detectedSignals" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=diamond;endFill=1;strokeColor=#444444;labelBackgroundColor=#ffffff;fontSize=10;fontColor=#000000;exitX=0.7;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" parent="1" source="allocCtx" target="detectedSig" edge="1">
