                </mxCell>
                <mxCell id="marginRateContent" value="value: Big&#10;{0 &lt; value &lt; 1。レバの逆数}&#10;--&#10;+ of(value): MarginRate&#10;+ toBig() / + toNumber()&#10;+ leverageEquivalent(): number&#10;{例: 0.04 → レバレッジ 25 倍}&#10;{業者依存値は infrastructure DI / R10}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#fff2cc;strokeColor=none;fontSize=10;fontColor=#000000;" parent="marginRate" vertex="1">
