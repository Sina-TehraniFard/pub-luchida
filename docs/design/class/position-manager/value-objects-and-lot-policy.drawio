                </mxCell>
                <mxCell id="maintRatioContent" value="value: Big&#10;{value &gt; 1.0（1.0 以下は throw）}&#10;{1.0 以下はロスカット境界}&#10;--&#10;+ of(value): MaintenanceRatio&#10;+ toBig() / + toNumber()&#10;{例: 1.4 → 140% 目標}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#fff2cc;strokeColor=none;fontSize=10;fontColor=#000000;" parent="maintRatio" vertex="1">
