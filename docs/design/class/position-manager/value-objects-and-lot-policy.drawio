                    <mxGeometry y="30" width="310" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="lotInput" value="LotDecisionInput&#10;ロット決定の入力（パラメータオブジェクト）" style="swimlane;fontStyle=1;align=center;startSize=45;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="340" y="580" width="760" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="lotInputContent" value="pair: CurrencyPair&#10;balance: Balance&#10;rate: Rate&#10;target: MaintenanceRatio&#10;marginRate: MarginRate&#10;--&#10;+ of(pair, balance, rate, target, marginRate): LotDecisionInput&#10;{不変条件 1: rate.pair() === pair（通貨ペア整合）}&#10;{不変条件 2: balance.currency と rate.pair.quote() が整合（JPY quote 前提）}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#dae8fc;strokeColor=none;fontSize=11;fontColor=#000000;" parent="lotInput" vertex="1">
                    <mxGeometry y="45" width="760" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="lotPolicyIf" value="&lt;&lt;interface&gt;&gt;&#10;LotPolicy" style="swimlane;fontStyle=1;align=center;startSize=45;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="430" y="820" width="580" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="lotPolicyIfContent" value="+ decide(input: LotDecisionInput): Lot&#10;--&#10;{純粋ドメインサービス。I/O なし。値オブジェクトだけで計算}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#e1d5e7;strokeColor=none;fontSize=11;fontColor=#000000;" parent="lotPolicyIf" vertex="1">
                    <mxGeometry y="45" width="580" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="maintLotPolicy" value="MaintenanceRatioBasedLotPolicy&#10;（旧 MarginBasedLotPolicy）" style="swimlane;fontStyle=1;align=center;startSize=45;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="390" y="1020" width="660" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="maintLotPolicyContent" value="+ decide(input: LotDecisionInput): Lot&#10;--&#10;前提（JPY quote 専用）:&#10;  if input.pair().quote() !== &apos;JPY&apos; → throw&#10;--&#10;計算（憲法 6.1: 経路は全て Big、最後の Lot.of でのみ number 化）:&#10;  raw     = capital / (target × rate × marginRate)&#10;  rounded = floor(raw / 100) × 100&#10;  clamped = clamp(rounded, MIN=100, MAX=500_000)&#10;  return Lot.of(clamped)&#10;--&#10;{純粋計算のみ。I/O を知らない}&#10;{維持率 target を満たす Lot を上限として決定}" style="text;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fillColor=#d5e8d4;strokeColor=none;fontSize=11;fontColor=#000000;" parent="maintLotPolicy" vertex="1">
                    <mxGeometry y="45" width="660" height="195" as="geometry"/>
                </mxCell>
                <mxCell id="groupNotes" value="設計のポイント" style="shape=mxgraph.basic.rect;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=4;rounded=1;arcSize=4;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1440" y="100" width="540" height="1240" as="geometry"/>
                </mxCell>
                <mxCell id="note1" value="値オブジェクトは不変条件を内部で守る&#10;&#10;・Balance: 非負&#10;・Ratio: 0〜1&#10;・MaintenanceRatio: 1.0 以上&#10;・MarginRate: 0〜1 の正値&#10;&#10;不正な値はコンストラクタで弾き、&#10;ドメインの内側には正しい値しか入らない" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="140" width="500" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="note2" value="LotPolicy は純粋ドメインサービス&#10;&#10;・I/O を一切持たない&#10;・引数は値オブジェクトだけで束ねる&#10;  （LotDecisionInput）&#10;・戻り値も値オブジェクト（Lot）&#10;&#10;→ テスト容易・差し替え容易&#10;→ 将来 VolatilityTargetingLotPolicy（#122）&#10;  などを実装差し替えで導入可能" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="360" width="500" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="note3" value="本改修の狙い：number 型を domain から追い出す&#10;&#10;・従来: number を domain が直に扱っていた&#10;  → 単位や不変条件が型に現れない&#10;  → 取り違えバグ・null チェックの氾濫&#10;&#10;・今回: Balance / Rate / MaintenanceRatio /&#10;  MarginRate / Ratio を整備&#10;  → 型だけで意味が伝わる&#10;  → null の居場所を境界に限定" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="600" width="500" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="note4" value="Rate は null を返さない&#10;&#10;・取得失敗は application 層で例外ハンドル&#10;・domain に null は渡さない&#10;・古レートでの発注事故を防ぐため、&#10;  取れない時は「発注中止」で良い&#10;&#10;現状 getCurrentRate(): number | null だが、&#10;本改修で Rate 値オブジェクトに置き換える" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="850" width="500" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="note5" value="命名の確定（brief.md 5.1 / R10）&#10;&#10;・DynamicLotCalculator → PositionSizingService&#10;・MarginBasedLotPolicy → MaintenanceRatioBasedLotPolicy&#10;・BalanceCache → GmoBalanceAdapter&#10;・MarginRate.gmoFxRetail() 削除&#10;  → infrastructure DI（GmoConstants.MARGIN_RATE）&#10;・AllocationPolicy.decide(...)（旧 .allocate）&#10;&#10;FX 業界用語とドメインの意図に寄せる。&#10;キャッシュ・業者依存値は実装詳細でクラス名に出さない。" style="shape=note;size=14;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="1070" width="500" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="constitution" value="設計憲法 6.1〜6.11（value-objects.md 6 章）&#10;&#10;6.1 Big 徹底  経路は Big で閉じ、Lot.of(number) の境界のみ number 化&#10;6.2 エラー階層  VO 不変条件違反は throw（将来 DomainValidationError 階層へ）&#10;6.3 Balance / AvailableBalance 分岐  必要時に別 VO 化&#10;6.4 テスト戦略  境界値・例外・等価性・不変性を VO ごとに必須&#10;6.5 equals と hashCode  Map キーには .value（StrategyNameValue）&#10;6.6 StrategyName 4 値固定  enum 前提（class 実装は #130 で singleton 化予定）&#10;6.7 domain VO は null を返さない  port 層のみ null 許容&#10;6.8 Pips × Rate の pip 精度連携  CurrencyPair.pipScale() 経由（#131）&#10;6.9 Rate.freshNow 運用  鮮度判定は RatePort 実装が担う&#10;6.10 Map 非露出  StrategyLots / LotAllocation で API 境界を覆う&#10;6.11 シリアライズはドメイン語彙  strategyName.value / pair.toString()" style="shape=note;size=14;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontColor=#000000;align=left;spacingLeft=8;fontStyle=0;" parent="1" vertex="1">
                    <mxGeometry x="50" y="1320" width="1340" height="280" as="geometry"/>
                </mxCell>
