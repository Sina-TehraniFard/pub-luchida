                <mxCell id="title" value="ヒゲ逆張り戦略 クラス図" style="text;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#333;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="344" y="-4" width="400" height="35" as="geometry"/>
