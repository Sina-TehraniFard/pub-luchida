                <mxCell id="note1" value="IndicatorLedgerはCompositeパターンで&#10;全Indicatorを保持し、一括更新する。&#10;値の取得は各Ruleが直接Indicatorに問い合わせる。&#10;IndicatorLedgerは更新のみ担当" style="shape=note;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=11;fontColor=#997a2d;align=left;whiteSpace=wrap;size=14;" parent="1" vertex="1">
                    <mxGeometry x="30" y="265" width="340" height="65" as="geometry"/>
                </mxCell>
