                <mxCell id="arr_ledger_has_indicator" value="has *" style="endArrow=open;endFill=0;strokeColor=#333333;fontSize=10;fontColor=#FFFFFF;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="ledger" target="indicator_if" edge="1">
