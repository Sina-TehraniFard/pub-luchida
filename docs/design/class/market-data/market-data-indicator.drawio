                </mxCell>
                <mxCell id="arr_ledger_indicator" value="implements" style="endArrow=block;endFill=0;dashed=1;strokeColor=#666666;fontSize=10;fontColor=#FFFFFF;" parent="1" source="note1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="200" y="178" as="targetPoint"/>
