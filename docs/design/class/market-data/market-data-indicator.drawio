                            <mxPoint x="400" y="125"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <!-- IndicatorValues は廃止。Rule がコンストラクタで Indicator を直接受け取る -->
                <mxCell id="design_note" value="【案C採用】IndicatorValues は廃止&#10;&#10;Rule は必要な Indicator をコンストラクタで&#10;直接受け取る。&#10;&#10;例: RsiReversalEntryRule(rsi: RsiIndicator)&#10;例: SmaCrossEntryRule(sma: SmaIndicator)&#10;&#10;Indicator の値取得は Rule の責務。&#10;IndicatorLedger は Indicator の更新&#10;（warmUp, onCandleConfirmed）だけを担う。&#10;&#10;「全指標の寄せ集め」はドメインの概念ではない。&#10;指標追加時に既存コードの変更が不要になる" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fff8e1;strokeColor=#f9a825;fontSize=11;fontColor=#5d4037;align=left;" parent="1" vertex="1">
                    <mxGeometry x="480" y="70" width="340" height="230" as="geometry"/>
