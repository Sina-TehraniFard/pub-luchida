                <!-- BarReconciler -> TimeFrameBook.reconcile -->
                <mxCell id="arr_rec_tfb" value="reconcile(tf, official)" style="endArrow=open;endFill=0;strokeColor=#333;fontSize=11;fontColor=#333;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;" parent="1" source="reconciler" target="tfb" edge="1">
