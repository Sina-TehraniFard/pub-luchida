<mxfile host="65bd71144e">
    <diagram name="RSI Reversal Rule Class Diagram" id="rsi_rule_class">
        <mxGraphModel dx="1104" dy="1186" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="bg" value="" style="whiteSpace=wrap;html=1;shadow=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="52" y="-36" width="1060" height="680" as="geometry"/>
                </mxCell>
                <mxCell id="title" value="RSI 逆張り戦略 クラス図" style="text;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#333;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="344" y="-4" width="400" height="35" as="geometry"/>
                </mxCell>

                <!-- EntryRule 参照ボックス（破線・グレー） -->
                <mxCell id="entry_rule_ref" value="&lt;&lt;interface&gt;&gt;&#10;EntryRule&#10;（rule-layer.drawio 参照）" style="swimlane;fontStyle=1;align=center;fontSize=14;fillColor=#f5f5f5;strokeColor=#999;startSize=60;fontColor=#666;dashed=1;dashPattern=8 4;" parent="1" vertex="1">
                    <mxGeometry x="80" y="60" width="320" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="entry_rule_ref_method" value="+ shouldEntry(snapshot: MarketSnapshot)&#10;    : EntryCommand | DoNothing" style="text;align=left;verticalAlign=top;fontSize=12;fontColor=#999;" parent="entry_rule_ref" vertex="1">
                    <mxGeometry y="60" width="320" height="40" as="geometry"/>
                </mxCell>

                <!-- ExitRule 参照ボックス（破線・グレー） -->
                <mxCell id="exit_rule_ref" value="&lt;&lt;interface&gt;&gt;&#10;ExitRule&#10;（rule-layer.drawio 参照）" style="swimlane;fontStyle=1;align=center;fontSize=14;fillColor=#f5f5f5;strokeColor=#999;startSize=60;fontColor=#666;dashed=1;dashPattern=8 4;" parent="1" vertex="1">
                    <mxGeometry x="80" y="400" width="320" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="exit_rule_ref_method" value="+ shouldExit(snapshot: MarketSnapshot,&#10;    position: Position)&#10;    : ExitCommand | DoNothing" style="text;align=left;verticalAlign=top;fontSize=12;fontColor=#999;" parent="exit_rule_ref" vertex="1">
                    <mxGeometry y="60" width="320" height="50" as="geometry"/>
                </mxCell>

                <!-- RsiReversalEntryRule -->
                <mxCell id="rsi_entry" value="RsiReversalEntryRule" style="swimlane;fontStyle=1;align=center;fontSize=14;fillColor=#dae8fc;strokeColor=#6c8ebf;startSize=30;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="540" y="60" width="340" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_entry_pkg" value="domain/rule/rsi" style="text;align=left;verticalAlign=top;fontSize=11;fontColor=#6c8ebf;fontStyle=2;" parent="rsi_entry" vertex="1">
                    <mxGeometry y="30" width="340" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_entry_attrs" value="- rsiIndicator: RsiIndicator&#10;- oversoldThreshold: number&#10;- overboughtThreshold: number" style="text;align=left;verticalAlign=top;fontSize=12;fontColor=#333;" parent="rsi_entry" vertex="1">
                    <mxGeometry y="50" width="340" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_entry_sep" value="" style="line;strokeColor=#6c8ebf;" parent="rsi_entry" vertex="1">
                    <mxGeometry y="70" width="340" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_entry_method" value="+ shouldEntry(snapshot: MarketSnapshot)&#10;    : EntryCommand | DoNothing&#10;&#10;RSI ≤ oversoldThreshold → BUY&#10;RSI ≥ overboughtThreshold → SELL&#10;（閾値はコンストラクタ注入）" style="text;align=left;verticalAlign=top;fontSize=12;fontColor=#333;" parent="rsi_entry" vertex="1">
                    <mxGeometry y="78" width="340" height="70" as="geometry"/>
                </mxCell>

                <!-- RsiReversalExitRule -->
                <mxCell id="rsi_exit" value="RsiReversalExitRule" style="swimlane;fontStyle=1;align=center;fontSize=14;fillColor=#dae8fc;strokeColor=#6c8ebf;startSize=30;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="540" y="400" width="340" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_exit_pkg" value="domain/rule/rsi" style="text;align=left;verticalAlign=top;fontSize=11;fontColor=#6c8ebf;fontStyle=2;" parent="rsi_exit" vertex="1">
                    <mxGeometry y="30" width="340" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_exit_attrs" value="- rsiIndicator: RsiIndicator&#10;- neutralZone: NeutralZone" style="text;align=left;verticalAlign=top;fontSize=12;fontColor=#333;" parent="rsi_exit" vertex="1">
                    <mxGeometry y="50" width="340" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_exit_sep" value="" style="line;strokeColor=#6c8ebf;" parent="rsi_exit" vertex="1">
                    <mxGeometry y="70" width="340" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_exit_method" value="+ shouldExit(snapshot: MarketSnapshot,&#10;    position: Position)&#10;    : ExitCommand | DoNothing&#10;&#10;RSI が 50 に戻ったら決済" style="text;align=left;verticalAlign=top;fontSize=12;fontColor=#333;" parent="rsi_exit" vertex="1">
                    <mxGeometry y="78" width="340" height="70" as="geometry"/>
                </mxCell>

                <!-- implements 矢印 -->
                <mxCell id="arr_impl_entry" value="implements" style="endArrow=block;endFill=0;dashed=1;strokeColor=#6c8ebf;fontSize=11;fontColor=#6c8ebf;fontStyle=2;" parent="1" source="rsi_entry" target="entry_rule_ref" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="arr_impl_exit" value="implements" style="endArrow=block;endFill=0;dashed=1;strokeColor=#6c8ebf;fontSize=11;fontColor=#6c8ebf;fontStyle=2;" parent="1" source="rsi_exit" target="exit_rule_ref" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- 付箋: RSI 閾値の説明 -->
                <mxCell id="rsi_note_entry" value="RSI（相対力指数）は直近の値動きの&#10;「買われすぎ / 売られすぎ」を 0〜100 で表す&#10;&#10;oversoldThreshold 以下 → 売られすぎ → BUY&#10;overboughtThreshold 以上 → 買われすぎ → SELL&#10;&#10;閾値はコンストラクタ注入。&#10;具体値はバックテストで決定する" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=11;fontColor=#997a2d;align=left;" parent="1" vertex="1">
                    <mxGeometry x="540" y="220" width="340" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_note_entry_arr" style="strokeColor=#d6b656;dashed=1;endArrow=none;" parent="1" source="rsi_note_entry" target="rsi_entry" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <mxCell id="rsi_note_exit" value="NeutralZone（値オブジェクト）で決済判定する&#10;NeutralZone = { low: number, high: number }&#10;neutralZone.contains(rsi) が true → 決済&#10;&#10;具体値はバックテストで決定する&#10;コンストラクタ注入でハードコードしない" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=11;fontColor=#997a2d;align=left;" parent="1" vertex="1">
                    <mxGeometry x="540" y="560" width="340" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="rsi_note_exit_arr" style="strokeColor=#d6b656;dashed=1;endArrow=none;" parent="1" source="rsi_note_exit" target="rsi_exit" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
