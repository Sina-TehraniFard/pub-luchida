{
  "name": "luchida",
  "version": "0.9.2",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/frontend",
    "packages/backtest"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint packages/backend/src packages/backtest/src",
    "format": "prettier --write packages/*/src",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=21.2.0"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.61.1"
  }
}
